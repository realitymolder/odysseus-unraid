<Container version="2">
  <Name>Odysseus-ChromaDB</Name>
  <Repository>docker.io/chromadb/chroma:latest</Repository>
  <Registry>https://registry.hub.docker.com</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/chroma-core/chroma/issues</Support>
  <Project>https://github.com/chroma-core/chroma</Project>
  <Overview>Vector store for Odysseus semantic memory (required companion).</Overview>
  <Description>ChromaDB is the vector database used by Odysseus for persistent semantic memory, skill storage, and vector keyword retrieval. This is a required companion for Odysseus — without it, memory and agent skills will not work.&#13;&#13;Ensure the container name matches the CHROMADB_HOST value configured in the main Odysseus template.</Description>
  <Category>AI:Tools</Category>
  <TemplateURL>https://raw.githubusercontent.com/realitymolder/Odysseus-Unraid/main/templates/odysseus-chromadb.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/realitymolder/Odysseus-Unraid/main/icon.svg</Icon>
  <Requires/>
  <Config Name="ChromaDB Port" Target="8000" Default="8000" Mode="tcp" Description="ChromaDB API port" Type="Port" Display="always" Required="true" Mask="false">8000</Config>
  <Config Name="Chroma Data" Target="/chroma/chroma" Default="/mnt/user/appdata/odysseus/chromadb" Mode="rw" Description="ChromaDB persistent data" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/odysseus/chromadb</Config>
  <Config Name="Telemetry" Target="ANONYMIZED_TELEMETRY" Default="FALSE" Description="Disable telemetry" Type="Variable" Display="always" Required="false" Mask="false">FALSE</Config>
</Container>
