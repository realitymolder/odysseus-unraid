<Container version="2">
  <Name>Odysseus</Name>
  <Repository>ghcr.io/realitymolder/odysseus-unraid:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/pewdiepie-archdaemon/odysseus/issues</Support>
  <Project>https://github.com/pewdiepie-archdaemon/odysseus</Project>
  <Overview>Self-hosted AI workspace with chat, agents, deep research, documents, email, calendar, and model Cookbook.</Overview>
  <Description>Odysseus is a self-hosted AI workspace — the self-hosted version of the UI experience you get from ChatGPT and Claude. Running on your own hardware, with your own data — local-first, privacy-first.&#13;&#13;Features:&#13;Chat with any local model or API (vLLM, llama.cpp, Ollama, OpenAI, OpenRouter, GitHub Copilot)&#13;Autonomous agents with MCP, web, files, shell, skills, memory&#13;Cookbook — scans your hardware, recommends models, click to download and serve&#13;Deep Research — multi-step research into visual reports&#13;Compare — blind test models side by side&#13;Documents editor with AI assistance&#13;Email — IMAP/SMTP inbox with AI triage&#13;Notes, Tasks, Calendar (CalDAV)&#13;Memory and Skills — persistent vector and keyword retrieval&#13;Works on mobile (PWA, responsive)&#13;&#13;Companion containers (install before Odysseus):&#13;Odysseus-ChromaDB (required) — vector store for semantic memory&#13;Odysseus-SearXNG (required) — meta search engine for web search&#13;Odysseus-ntfy (optional) — push notifications&#13;&#13;One-click install (alternative): Install the Docker Compose Manager plugin and import the compose file from https://raw.githubusercontent.com/realitymolder/Odysseus-Unraid/main/docker-compose.yml — deploys all 4 containers as a single stack.</Description>
  <Category>AI:Tools</Category>
  <WebUI>http://[IP]:[PORT:7000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/realitymolder/Odysseus-Unraid/main/templates/odysseus.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/realitymolder/Odysseus-Unraid/main/icon.svg</Icon>
  <DonorText>Support Odysseus development</DonorText>
  <DonorLink>https://github.com/pewdiepie-archdaemon/odysseus</DonorLink>
  <Requires>
    <Requires>Odysseus-ChromaDB</Requires>
    <Requires>Odysseus-SearXNG</Requires>
    <Requires>Odysseus-ntfy</Requires>
  </Requires>

  <Config Name="App Port" Target="7000" Default="7000" Mode="tcp" Description="Web UI port" Type="Port" Display="always" Required="true" Mask="false">7000</Config>
  <Config Name="App Data" Target="/app/data" Default="/mnt/user/appdata/odysseus/data" Mode="rw" Description="Persistent data storage (database, uploads, memory)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/odysseus/data</Config>
  <Config Name="App Logs" Target="/app/logs" Default="/mnt/user/appdata/odysseus/logs" Mode="rw" Description="Application logs" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/odysseus/logs</Config>
  <Config Name="HF Cache" Target="/app/.cache/huggingface" Default="/mnt/user/appdata/odysseus/huggingface" Mode="rw" Description="HuggingFace model cache" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/odysseus/huggingface</Config>
  <Config Name="Local Cache" Target="/app/.local" Default="/mnt/user/appdata/odysseus/local" Mode="rw" Description="Cookbook-installed engines (vLLM, llama.cpp)" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/odysseus/local</Config>
  <Config Name="SSH Keys" Target="/app/.ssh" Default="/mnt/user/appdata/odysseus/ssh" Mode="rw" Description="Cookbook remote-server SSH keys" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/odysseus/ssh</Config>
  <Config Name="PUID" Target="PUID" Default="99" Description="User ID for file permissions (default 99 = nobody)" Type="Variable" Display="always" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Description="Group ID for file permissions (default 100 = users)" Type="Variable" Display="always" Required="false" Mask="false">100</Config>
  <Config Name="Auth Enabled" Target="AUTH_ENABLED" Default="true" Description="Enable authentication" Type="Variable" Display="always" Required="false" Mask="false">true</Config>
  <Config Name="Admin User" Target="ODYSSEUS_ADMIN_USER" Default="admin" Description="First admin account username" Type="Variable" Display="always" Required="false" Mask="false">admin</Config>
  <Config Name="Admin Password" Target="ODYSSEUS_ADMIN_PASSWORD" Default="" Description="Pre-seed admin password (leave blank for auto-generated)" Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="App Port" Target="APP_PORT" Default="7000" Description="Internal app port (leave as 7000)" Type="Variable" Display="always" Required="false" Mask="false">7000</Config>
  <Config Name="LLM Host" Target="LLM_HOST" Default="localhost" Description="Primary LLM server hostname" Type="Variable" Display="always" Required="false" Mask="false">localhost</Config>
  <Config Name="OpenAI API Key" Target="OPENAI_API_KEY" Default="" Description="Optional OpenAI API key" Type="Variable" Display="always" Required="false" Mask="true"></Config>
  <Config Name="SearXNG Instance" Target="SEARXNG_INSTANCE" Default="http://odysseus-searxng:8080" Description="SearXNG URL (compose: searxng:8080, branded template: odysseus-searxng:8080)" Type="Variable" Display="always" Required="false" Mask="false">http://odysseus-searxng:8080</Config>
  <Config Name="ChromaDB Host" Target="CHROMADB_HOST" Default="odysseus-chromadb" Description="ChromaDB host (internal Docker hostname)" Type="Variable" Display="always" Required="false" Mask="false">odysseus-chromadb</Config>
  <Config Name="ChromaDB Port" Target="CHROMADB_PORT" Default="8000" Description="ChromaDB port" Type="Variable" Display="always" Required="false" Mask="false">8000</Config>
  <Config Name="Database URL" Target="DATABASE_URL" Default="sqlite:///./data/app.db" Description="Database connection string" Type="Variable" Display="always" Required="false" Mask="false">sqlite:///./data/app.db</Config>
  <Config Name="Extra Hosts" Target="EXTRA_HOSTS" Default="host.docker.internal:host-gateway" Description="Extra hosts mapping (for reaching host services like Ollama)" Type="Variable" Display="always" Required="false" Mask="false">host.docker.internal:host-gateway</Config>
</Container>
